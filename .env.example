# Copy to .env (`cp .env.example .env`) before running `make up`.
# These defaults are for local development only — never reuse them in prod.

# ── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=segdemo
POSTGRES_PASSWORD=segdemo
POSTGRES_DB=segdemo
# Async SQLAlchemy URL consumed by the API (M1). Host `postgres` is the compose
# service name; use `localhost` when connecting from the host.
DATABASE_URL=postgresql+asyncpg://segdemo:segdemo@postgres:5432/segdemo

# ── NATS ─────────────────────────────────────────────────────────────────────
# Client URL for the API and worker. HTTP monitoring is on :8222.
NATS_URL=nats://nats:4222

# ── Object storage (MinIO in dev, AWS S3 in prod) ────────────────────────────
# When S3_ENDPOINT is set, clients use MinIO with path-style addressing.
# Leave it unset in prod to fall back to real AWS S3 (M5).
S3_ENDPOINT=http://minio:9000
# Endpoint baked into presigned URLs handed back to clients. The API reaches
# MinIO at the internal `minio` hostname, but a browser/curl on the host can
# only reach it at localhost — so presigning uses this. Leave unset in prod.
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
# Standard AWS-style credentials. In dev these match the MinIO root creds below.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# MinIO root credentials (dev container only).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Buckets created by the minio-init one-shot.
RAW_BUCKET=raw
ANNOTATED_BUCKET=annotated

# Presigned URL lifetime in seconds (M1). Default 15 minutes.
PRESIGNED_URL_TTL=900
